# Backend AI provider. OPENAI has priority when both keys are set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# Server-side key. The browser receives only a short-lived Deepgram token.
DEEPGRAM_API_KEY=

# PostgreSQL. Always replace the password in production.
POSTGRES_DB=zoomscribe
POSTGRES_USER=zoomscribe
POSTGRES_PASSWORD=change-me-in-production
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
WEB_CONCURRENCY=2

# Public frontend port on the server.
FRONTEND_PORT=8080

# Only needed when the backend is called directly from another origin.
# With the included Nginx frontend proxy, same-origin /api requests do not need CORS.
CORS_ORIGINS=http://localhost:8080

# Set true behind an HTTPS domain.
COOKIE_SECURE=false
ALLOW_REGISTRATION=true

# Google OAuth. Create these in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
FRONTEND_URL=http://localhost:8080

# Comma-separated list of admin emails.
ADMIN_EMAILS=
