# Backend AI provider. GROQ has priority when both keys are set.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
ANTHROPIC_API_KEY=

# Browser-side Deepgram key. Important: VITE_* values are baked into the frontend
# bundle and are visible in DevTools after deployment.
VITE_DEEPGRAM_API_KEY=

# Public frontend port on the server.
FRONTEND_PORT=8080

# Only needed when the backend is called directly from another origin.
# With the included Nginx frontend proxy, same-origin /api requests do not need CORS.
CORS_ORIGINS=http://localhost:8080
